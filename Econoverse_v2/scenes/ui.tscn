[node name="ui_explained" type="Label" parent="FullScreenArranged/PanelCenter/BoxCenterPRIMARY" unique_id=1005028315]
visible = false
custom_minimum_size = Vector2(200, 0)
layout_mode = 2
theme_override_styles/normal = ExtResource("6_p7vwb")
text = "Hide this label when not using it typically, but maybe use a label in this space for in-game messages of sorts, during pauses etc. 

The PanelCenter element where this label resides will always expand to position the top and bottom rows properly. This is acheived by enforcing custom minimum size of panels. Should be safe to display whatever we want in the BoxCenterPRIMARY. The box arranges like a typical HBox for now.

Notifications and popups will not interact with the size and spacing of this content. They draw on top of anything in BoxCenterPRIMARY as well, so should be appear-and-fade elements only in notifications and popups... maybe have a way to view notificaiton history though.

Big pretty box with big pretty text. Yellow."
label_settings = SubResource("LabelSettings_ktti3")
autowrap_mode = 3

