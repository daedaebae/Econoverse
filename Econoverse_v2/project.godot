; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Econoverse_v2"
run/main_scene="uid://c8v5s5eqhgm3c"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.005599999, 0.014186656, 0.07, 1)
boot_splash/image="uid://bk5gkpxrqwd4o"
config/icon="uid://bk5gkpxrqwd4o"
boot_splash/minimum_display_time=500

[audio]

buses/default_bus_layout="uid://yicjv23th881"

[autoload]

GameController="*res://singleton/game_controller.gd"
UI="*uid://cr681lcqswbv5"
UITrade="*res://singleton/ui_trade.gd"
CharacterNode="*res://scripts/actors/Class_Character.gd"
AudioMaster="*res://singleton/audio_master.tscn"
AudioMasterScript="*res://singleton/audio_master_script.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/always_on_top=true
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="Econoverse_v2"

[editor_plugins]

enabled=PackedStringArray("res://addons/Todo_Manager/plugin.cfg")

[file_customization]

folder_colors={
"res://`_design/": "pink",
"res://assets/": "orange",
"res://scenes/": "yellow",
"res://scripts/": "green",
"res://singleton/": "purple"
}

